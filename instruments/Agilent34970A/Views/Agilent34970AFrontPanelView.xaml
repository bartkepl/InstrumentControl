<UserControl x:Class="Agilent34970A.Views.Agilent34970AFrontPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Agilent34970A.Views"
             mc:Ignorable="d"
             d:DesignHeight="660" d:DesignWidth="960"
             Background="#D4D0CC">

    <UserControl.Resources>
        <!-- ── Colours ── -->
        <SolidColorBrush x:Key="PanelBg"      Color="#D4D0CC"/>
        <SolidColorBrush x:Key="SidebarBg"    Color="#C0BCB8"/>
        <SolidColorBrush x:Key="HeaderBg"     Color="#B0ACA8"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#1A73C8"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#1E8040"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#C02010"/>
        <SolidColorBrush x:Key="AccentTeal"   Color="#0E7490"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#101010"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#505050"/>
        <SolidColorBrush x:Key="ControlBg"    Color="#C8C4C0"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#9A9694"/>

        <!-- ── Buttons ── -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.70"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.40"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
        </Style>
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="TealButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentTeal}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,6,0,2"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"      Value="0,4,0,0"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background"   Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1,1,1,0" CornerRadius="4,4,0,0"
                                Margin="2,2,2,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{Binding Foreground,
                                                  RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResultsGrid" TargetType="DataGrid">
            <Setter Property="Background"           Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground"        Value="{StaticResource ControlBg}"/>
            <Setter Property="AlternatingRowBackground" Value="#D4D0C8"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderColor}"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserResizeRows"    Value="False"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
            <Setter Property="ColumnWidth"          Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- ── Digital bit toggle ── -->
        <Style x:Key="BitToggle" TargetType="ToggleButton">
            <Setter Property="Width"   Value="32"/>
            <Setter Property="Height"  Value="32"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BitIndicator" TargetType="Ellipse">
            <Setter Property="Width"  Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Fill"   Value="#A0A098"/>
            <Setter Property="Stroke" Value="{StaticResource BorderColor}"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <!-- ════════════ DataTemplate: jeden port cyfrowy ════════════ -->
        <DataTemplate DataType="{x:Type vm:DioPortViewModel}">
            <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <TextBlock Text="Wejście (odczyt)" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit7Brush}"/><TextBlock Text="7" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit6Brush}"/><TextBlock Text="6" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit5Brush}"/><TextBlock Text="5" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit4Brush}"/><TextBlock Text="4" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <Rectangle Width="1" Fill="{StaticResource BorderColor}" Margin="5,0"/>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit3Brush}"/><TextBlock Text="3" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit2Brush}"/><TextBlock Text="2" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit1Brush}"/><TextBlock Text="1" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                        <StackPanel Margin="3,0"><Ellipse Style="{StaticResource BitIndicator}" Fill="{Binding InputBit0Brush}"/><TextBlock Text="0" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMuted}"/></StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding InputValue, StringFormat='0x{0:X2} ({0})'}"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <Button Content="ODCZYTAJ" Style="{StaticResource TealButton}"
                            Command="{Binding ReadCommand}" Margin="0,8,0,12"
                            HorizontalAlignment="Center" Width="120"/>

                    <TextBlock Text="Wyjście" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit7}" Margin="2" Content="7"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit6}" Margin="2" Content="6"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit5}" Margin="2" Content="5"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit4}" Margin="2" Content="4"/>
                        <Rectangle Width="1" Fill="{StaticResource BorderColor}" Margin="5,0"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit3}" Margin="2" Content="3"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit2}" Margin="2" Content="2"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit1}" Margin="2" Content="1"/>
                        <ToggleButton Style="{StaticResource BitToggle}" IsChecked="{Binding OutputBit0}" Margin="2" Content="0"/>
                    </StackPanel>
                    <TextBlock Text="{Binding OutputValue, StringFormat='0x{0:X2} ({0})'}"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <Button Content="ZAPISZ" Style="{StaticResource RedButton}"
                            Command="{Binding WriteCommand}" Margin="0,8,0,0"
                            HorizontalAlignment="Center" Width="120"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ════════════ DataTemplate: zakładka MUX 34901A ════════════ -->
        <DataTemplate DataType="{x:Type vm:Mux34901AViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="POMIAR MULTIPLEKSERA — każdy kanał z własną funkcją"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ChannelHint}" FontSize="10"
                               Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <DataGrid ItemsSource="{Binding ChannelConfigs}"
                              SelectedItem="{Binding SelectedConfigRow}"
                              Style="{StaticResource ResultsGrid}"
                              IsReadOnly="True" Height="190">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Kanał" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox MinWidth="70" Margin="2" BorderThickness="0"
                                                  ItemsSource="{Binding AvailableChannels}"
                                                  SelectedItem="{Binding Channel, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Funkcja" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox MinWidth="110" Margin="2" BorderThickness="0"
                                                  ItemsSource="{Binding FunctionOptions}"
                                                  SelectedItem="{Binding Function, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Zakres" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox MinWidth="80" Margin="2" IsEditable="True"
                                                  Text="{Binding Range, UpdateSourceTrigger=LostFocus}">
                                            <ComboBoxItem Content="AUTO"/>
                                            <ComboBoxItem Content="DEF"/>
                                            <ComboBoxItem Content="MIN"/>
                                            <ComboBoxItem Content="MAX"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Param" Width="Auto" MinWidth="50"
                                                Binding="{Binding Param}"/>
                            <DataGridTextColumn Header="NPLC" Width="Auto" MinWidth="50"
                                                Binding="{Binding Nplc}"/>
                            <DataGridTextColumn Header="Rozdz." Width="Auto" MinWidth="50"
                                                Binding="{Binding Resolution}"/>
                            <DataGridTextColumn Header="Skalowanie Mx+B" Width="*" MinWidth="120"
                                                Binding="{Binding ScaleSummary}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Buttons -->
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="+ Wiersz" Style="{StaticResource ActionButton}"
                                Command="{Binding AddRowCommand}" Height="32" Margin="0,0,8,8"/>
                        <Button Content="− Usuń" Style="{StaticResource RedButton}"
                                Command="{Binding RemoveRowCommand}" Height="32" Margin="0,0,8,8"/>
                        <Button Content="Konfig. kanału…" Style="{StaticResource ActionButton}"
                                Command="{Binding OpenChannelConfigCommand}" Height="32" Margin="0,0,8,8"/>
                        <Button Content="Konfig. skanu…" Style="{StaticResource ActionButton}"
                                Command="{Binding OpenScanConfigCommand}" Height="32" Margin="0,0,8,8"/>
                        <Button Content="▶  SKANUJ" Style="{StaticResource GreenButton}"
                                Command="{Binding ScanCommand}" Height="32" Width="120" Margin="0,0,8,8"/>
                        <Button Width="110" Height="32" Margin="0,0,8,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                    <Setter Property="Content" Value="▶  CIĄGŁY"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsContinuousScan}" Value="True">
                                            <Setter Property="Content" Value="■  STOP"/>
                                            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Command><Binding Path="ToggleContinuousScanCommand"/></Button.Command>
                        </Button>
                        <ComboBox ItemsSource="{Binding ScanIntervals}"
                                  SelectedItem="{Binding SelectedScanInterval}"
                                  Height="32" Width="80" Margin="0,0,0,8"/>
                    </WrapPanel>

                    <TextBlock Text="WYNIKI" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,12,0,6"/>
                    <DataGrid ItemsSource="{Binding ScanResults}" Style="{StaticResource ResultsGrid}" Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kanał"     Width="Auto" MinWidth="60"  Binding="{Binding ChannelId}"/>
                            <DataGridTextColumn Header="Wartość"   Width="Auto" MinWidth="110" Binding="{Binding Value, StringFormat=G8}"/>
                            <DataGridTextColumn Header="Jednostka" Width="Auto" MinWidth="80"  Binding="{Binding Unit}"/>
                            <DataGridTextColumn Header="Funkcja"   Width="Auto" MinWidth="100" Binding="{Binding Function}"/>
                            <DataGridTextColumn Header="Czas"      Width="Auto" MinWidth="100" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ════════════ DataTemplate: zakładka 34907A ════════════ -->
        <DataTemplate DataType="{x:Type vm:Multi34907AViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock Text="MODUŁ WIELOFUNKCYJNY 34907A"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                    <!-- DAC — dwa wyjścia obok siebie -->
                    <TextBlock Text="{Binding DacRangeHint}" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- DAC 1 -->
                        <Border Grid.Column="0" Background="{StaticResource ControlBg}"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="DAC 1" FontWeight="Bold" FontSize="13"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Dac1Voltage, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="14" VerticalContentAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <Button Content="▲" Width="26" Height="16" Padding="0" FontSize="9"
                                                Style="{StaticResource ActionButton}" Command="{Binding Dac1UpCommand}"/>
                                        <Button Content="▼" Width="26" Height="16" Padding="0" FontSize="9" Margin="0,2,0,0"
                                                Style="{StaticResource ActionButton}" Command="{Binding Dac1DownCommand}"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="Ustaw DAC 1" Style="{StaticResource GreenButton}"
                                        Command="{Binding SetDac1Command}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- DAC 2 -->
                        <Border Grid.Column="2" Background="{StaticResource ControlBg}"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="DAC 2" FontWeight="Bold" FontSize="13"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Dac2Voltage, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="14" VerticalContentAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <Button Content="▲" Width="26" Height="16" Padding="0" FontSize="9"
                                                Style="{StaticResource ActionButton}" Command="{Binding Dac2UpCommand}"/>
                                        <Button Content="▼" Width="26" Height="16" Padding="0" FontSize="9" Margin="0,2,0,0"
                                                Style="{StaticResource ActionButton}" Command="{Binding Dac2DownCommand}"/>
                                    </StackPanel>
                                </Grid>
                                <Button Content="Ustaw DAC 2" Style="{StaticResource GreenButton}"
                                        Command="{Binding SetDac2Command}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="Krok DAC [V]:" Style="{StaticResource FieldLabel}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding DacStep, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80" FontFamily="Consolas"/>
                    </StackPanel>

                    <!-- Digital I/O: dwa porty obok siebie -->
                    <TextBlock Text="CYFROWE I/O" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ContentControl Grid.Column="0" Content="{Binding Port1}"/>
                        <ContentControl Grid.Column="2" Content="{Binding Port2}"/>
                    </Grid>

                    <!-- Totalizer -->
                    <Border Background="{StaticResource ControlBg}" BorderBrush="{StaticResource AccentTeal}"
                            BorderThickness="1" CornerRadius="6" Padding="14">
                        <StackPanel>
                            <TextBlock Text="TOTALIZATOR IMPULSÓW (kanał s03)"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource AccentTeal}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#051210" BorderBrush="{StaticResource AccentTeal}"
                                        BorderThickness="1" CornerRadius="3" Padding="12,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding TotalizerValueText}" Foreground="{StaticResource AccentTeal}"
                                               FontFamily="Consolas" FontSize="16" MinWidth="80" TextAlignment="Right"/>
                                </Border>
                                <Button Grid.Column="1" Content="ODCZYTAJ" Style="{StaticResource TealButton}"
                                        Command="{Binding ReadTotalizerCommand}" Width="90" Height="30"/>
                                <Button Grid.Column="3" Content="RESET" Style="{StaticResource RedButton}"
                                        Command="{Binding ResetTotalizerCommand}" Width="70" Height="30"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <Border Background="{StaticResource HeaderBg}" Padding="12,14">
                        <StackPanel>
                            <TextBlock Text="AGILENT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                            <TextBlock Text="34970A" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Data Acquisition / Switch Unit" FontSize="10"
                                       Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="KONFIGURACJA KART" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" Margin="12,12,12,4"/>
                    <Button Content="WYKRYJ KARTY" Style="{StaticResource ActionButton}"
                            Command="{Binding DetectCardsCommand}" Margin="12,2,12,6" Height="30"/>

                    <Expander Header="Slot 100" Margin="8,4,8,0" IsExpanded="True">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}" SelectedItem="{Binding Slot100CardType}"/>
                        </StackPanel>
                    </Expander>
                    <Expander Header="Slot 200" Margin="8,4,8,0">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}" SelectedItem="{Binding Slot200CardType}"/>
                        </StackPanel>
                    </Expander>
                    <Expander Header="Slot 300" Margin="8,4,8,0">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}" SelectedItem="{Binding Slot300CardType}"/>
                        </StackPanel>
                    </Expander>

                    <Border Background="#B8B4B0" Margin="8,16,8,8" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentGreen}"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══ DYNAMIC CARD TABS ═══ -->
            <Grid Grid.Column="1">
                <TabControl ItemsSource="{Binding CardTabs}" SelectedItem="{Binding SelectedTab}"
                            Margin="8" Visibility="{Binding TabsVisibility}">
                    <TabControl.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Header}"/></DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
                <TextBlock Text="Brak skonfigurowanych kart. Kliknij WYKRYJ KARTY lub wybierz typ karty dla slotu."
                           Visibility="{Binding EmptyVisibility}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                           FontSize="13" TextAlignment="Center" Margin="40"/>
            </Grid>
        </Grid>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Border Grid.Row="1" Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="RESET" Style="{StaticResource RedButton}"
                        Command="{Binding ResetCommand}" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="STATUS" Style="{StaticResource ActionButton}"
                        Command="{Binding QueryStatusCommand}"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11"/>
                <TextBlock Grid.Column="3" Text="Agilent 34970A v2.1" Foreground="#808080"
                           VerticalAlignment="Center" FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
