<UserControl x:Class="Agilent34970A.Views.Agilent34970AFrontPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="900"
             Background="#D4D0CC">

    <UserControl.Resources>
        <!-- ── Colours: authentic Agilent 34970A light gray body ── -->
        <SolidColorBrush x:Key="PanelBg"      Color="#D4D0CC"/>
        <SolidColorBrush x:Key="SidebarBg"    Color="#C0BCB8"/>
        <SolidColorBrush x:Key="HeaderBg"     Color="#B0ACA8"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#1A73C8"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#1E8040"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#C02010"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#1565A0"/>
        <SolidColorBrush x:Key="AccentTeal"   Color="#0E7490"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#101010"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#505050"/>
        <SolidColorBrush x:Key="ControlBg"    Color="#C8C4C0"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#9A9694"/>

        <!-- ── Base button style ── -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
        </Style>
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
        </Style>
        <Style x:Key="TealButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource AccentTeal}"/>
        </Style>

        <!-- ── Label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,6,0,2"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- ── ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
        </Style>

        <!-- ── Expander ── -->
        <Style TargetType="Expander">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"      Value="0,4,0,0"/>
        </Style>

        <!-- ── TabControl / TabItem ── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"   Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Margin="2,2,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{Binding Foreground,
                                                  RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                        Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"           Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"          Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground"        Value="{StaticResource ControlBg}"/>
            <Setter Property="AlternatingRowBackground" Value="#D4D0C8"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource BorderColor}"/>
            <Setter Property="AutoGenerateColumns"  Value="False"/>
            <Setter Property="IsReadOnly"           Value="True"/>
            <Setter Property="SelectionMode"        Value="Single"/>
            <Setter Property="CanUserResizeRows"    Value="False"/>
            <Setter Property="HeadersVisibility"    Value="Column"/>
        </Style>

        <!-- ── Digital bit toggle button ── -->
        <Style x:Key="BitToggle" TargetType="ToggleButton">
            <Setter Property="Width"   Value="34"/>
            <Setter Property="Height"  Value="34"/>
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Digital input indicator (Ellipse inside border) ── -->
        <Style x:Key="BitIndicator" TargetType="Ellipse">
            <Setter Property="Width"  Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Fill"   Value="#A0A098"/>
            <Setter Property="Stroke" Value="{StaticResource BorderColor}"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════ MAIN AREA ══════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════ LEFT SIDEBAR ═══════════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBg}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0">
                <StackPanel>
                    <!-- Instrument header -->
                    <Border Background="{StaticResource HeaderBg}" Padding="12,14">
                        <StackPanel>
                            <TextBlock Text="AGILENT"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBlue}"/>
                            <TextBlock Text="34970A"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Data Acquisition / Switch Unit"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Card config -->
                    <TextBlock Text="KONFIGURACJA KART"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="12,12,12,4"/>

                    <!-- Slot 100 -->
                    <Expander Header="Slot 100" Margin="8,4,8,0" IsExpanded="True">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}"
                                      SelectedItem="{Binding Slot100CardType}"/>
                        </StackPanel>
                    </Expander>

                    <!-- Slot 200 -->
                    <Expander Header="Slot 200" Margin="8,4,8,0">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}"
                                      SelectedItem="{Binding Slot200CardType}"/>
                        </StackPanel>
                    </Expander>

                    <!-- Slot 300 -->
                    <Expander Header="Slot 300" Margin="8,4,8,0">
                        <StackPanel Margin="8,4,8,8">
                            <TextBlock Text="Typ karty:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CardTypes}"
                                      SelectedItem="{Binding Slot300CardType}"/>
                        </StackPanel>
                    </Expander>

                    <!-- Status -->
                    <Border Background="#B8B4B0" Margin="8,16,8,8"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="4" Padding="8">
                        <StackPanel>
                            <TextBlock Text="STATUS" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource AccentGreen}"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══════════ RIGHT PANEL ═══════════ -->
            <TabControl Grid.Column="1" Margin="8">

                <!-- ─── Tab 1: Skanowanie ─── -->
                <TabItem Header="Skanowanie">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="SKANOWANIE KANAŁÓW"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- Channel list -->
                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="Lista kanałów (np. 101,102,201:205):"
                                               Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding ChannelList, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"/>
                                </StackPanel>

                                <!-- Function -->
                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="Funkcja:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding AvailableFunctions}"
                                              SelectedItem="{Binding SelectedFunction}"/>
                                </StackPanel>

                                <!-- Scan buttons row -->
                                <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="▶  SKANUJ"
                                            Style="{StaticResource ActionButton}"
                                            Command="{Binding ScanCommand}"
                                            Height="34" FontSize="13"/>
                                    <Button Grid.Column="2" Width="120" Height="34">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                <Setter Property="Content" Value="▶  CIĄGŁY"/>
                                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsContinuousScan}" Value="True">
                                                        <Setter Property="Content" Value="■  STOP"/>
                                                        <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Command>
                                            <Binding Path="ToggleContinuousScanCommand"/>
                                        </Button.Command>
                                    </Button>
                                    <TextBlock Grid.Column="4"
                                               Text="Interwał:" Foreground="{StaticResource TextMuted}"
                                               FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding ScanIntervals}"
                                              SelectedItem="{Binding SelectedScanInterval}"
                                              Width="75" Height="34" Margin="4,0,0,0"/>
                                </Grid>
                            </Grid>

                            <!-- Results DataGrid -->
                            <TextBlock Text="WYNIKI" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,16,0,6"/>

                            <DataGrid ItemsSource="{Binding ScanResults}"
                                      Height="240">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kanał"     Width="80"
                                                        Binding="{Binding ChannelId}"/>
                                    <DataGridTextColumn Header="Wartość"   Width="*"
                                                        Binding="{Binding Value, StringFormat=G8}"/>
                                    <DataGridTextColumn Header="Jednostka" Width="80"
                                                        Binding="{Binding Unit}"/>
                                    <DataGridTextColumn Header="Funkcja"   Width="90"
                                                        Binding="{Binding Function}"/>
                                    <DataGridTextColumn Header="Czas"      Width="100"
                                                        Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─── Tab 2: DAC Wyjścia ─── -->
                <TabItem Header="DAC Wyjścia">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="WYJŚCIA DAC (34907A)"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,16"/>

                            <!-- Slot selector -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Slot (34907A):"
                                           Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding AvailableSlots}"
                                          SelectedItem="{Binding SelectedSlotFor34907A}"
                                          Width="90"/>
                            </StackPanel>

                            <!-- DAC 1 -->
                            <Border Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="16" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="DAC 1"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource TextPrimary}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Dac1Voltage, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="14"
                                             VerticalContentAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="V" Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="Ustaw"
                                                Style="{StaticResource GreenButton}"
                                                Command="{Binding SetDac1Command}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- DAC 2 -->
                            <Border Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="DAC 2"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="{StaticResource TextPrimary}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Dac2Voltage, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="14"
                                             VerticalContentAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                        <TextBlock Text="V" Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="Ustaw"
                                                Style="{StaticResource GreenButton}"
                                                Command="{Binding SetDac2Command}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─── Tab 3: Digital I/O ─── -->
                <TabItem Header="Digital I/O">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="CYFROWE I/O (34907A)"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,16"/>

                            <!-- Input indicators -->
                            <Border Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="WEJŚCIE CYFROWE (tylko odczyt)"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Bit 7 down to 0 -->
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit7Brush}"/>
                                            <TextBlock Text="7" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit6Brush}"/>
                                            <TextBlock Text="6" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit5Brush}"/>
                                            <TextBlock Text="5" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit4Brush}"/>
                                            <TextBlock Text="4" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <!-- separator -->
                                        <Rectangle Width="1" Fill="{StaticResource BorderColor}"
                                                   Margin="8,0"/>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit3Brush}"/>
                                            <TextBlock Text="3" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit2Brush}"/>
                                            <TextBlock Text="2" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit1Brush}"/>
                                            <TextBlock Text="1" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Margin="4,0">
                                            <Ellipse Style="{StaticResource BitIndicator}"
                                                     Fill="{Binding InputBit0Brush}"/>
                                            <TextBlock Text="0" FontSize="9"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DigitalInputValue, StringFormat='Wartość: 0x{0:X2} ({0})'}"
                                               Foreground="{StaticResource TextPrimary}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                    <Button Content="ODCZYTAJ"
                                            Style="{StaticResource TealButton}"
                                            Command="{Binding ReadDigitalCommand}"
                                            Margin="0,10,0,0" HorizontalAlignment="Center"
                                            Width="120"/>
                                </StackPanel>
                            </Border>

                            <!-- Output toggles -->
                            <Border Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="WYJŚCIE CYFROWE"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit7}" Margin="3" Content="7"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit6}" Margin="3" Content="6"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit5}" Margin="3" Content="5"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit4}" Margin="3" Content="4"/>
                                        <Rectangle Width="1" Fill="{StaticResource BorderColor}"
                                                   Margin="6,0"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit3}" Margin="3" Content="3"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit2}" Margin="3" Content="2"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit1}" Margin="3" Content="1"/>
                                        <ToggleButton Style="{StaticResource BitToggle}"
                                                      IsChecked="{Binding OutputBit0}" Margin="3" Content="0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DigitalOutputValue, StringFormat='Wartość: 0x{0:X2} ({0})'}"
                                               Foreground="{StaticResource TextPrimary}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                    <Button Content="ZAPISZ"
                                            Style="{StaticResource RedButton}"
                                            Command="{Binding WriteDigitalCommand}"
                                            Margin="0,10,0,0" HorizontalAlignment="Center"
                                            Width="120"/>
                                </StackPanel>
                            </Border>

                            <!-- Totalizer section -->
                            <Border Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource AccentTeal}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="TOTALIZATOR IMPULSÓW (34907A)"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentTeal}"
                                               Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Slot:"
                                                   Style="{StaticResource FieldLabel}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding TotalizerSlots}"
                                                  SelectedItem="{Binding TotalizerSlot}"
                                                  Width="80" Height="30"/>
                                        <Border Grid.Column="2"
                                                Background="#051210" BorderBrush="{StaticResource AccentTeal}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="12,4" Margin="8,0">
                                            <TextBlock Text="{Binding TotalizerValueText}"
                                                       Foreground="{StaticResource AccentTeal}"
                                                       FontFamily="Consolas" FontSize="16"
                                                       MinWidth="80" TextAlignment="Right"/>
                                        </Border>
                                        <Button Grid.Column="4" Content="ODCZYTAJ"
                                                Style="{StaticResource TealButton}"
                                                Command="{Binding ReadTotalizerCommand}"
                                                Width="90" Height="30"/>
                                        <Button Grid.Column="6" Content="RESET"
                                                Style="{StaticResource RedButton}"
                                                Command="{Binding ResetTotalizerCommand}"
                                                Width="70" Height="30"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ─── Tab 4: Temperatura TC ─── -->
                <TabItem Header="Temperatura">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <TextBlock Text="POMIAR TEMPERATURY TC / RTD"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <!-- Channel list -->
                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="Lista kanałów (np. 101,102):"
                                               Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding TempChannelList, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas"/>
                                </StackPanel>

                                <!-- TC type -->
                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="Typ termoelementa:" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox ItemsSource="{Binding TcTypes}"
                                              SelectedItem="{Binding SelectedTempTcType}"/>
                                </StackPanel>

                                <!-- Scan buttons -->
                                <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="▶  ZMIERZ TEMP"
                                            Style="{StaticResource TealButton}"
                                            Command="{Binding ScanTemperatureCommand}"
                                            Height="34" FontSize="12"/>
                                    <Button Grid.Column="2" Width="120" Height="34">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                <Setter Property="Content" Value="▶  CIĄGŁY"/>
                                                <Setter Property="Background" Value="{StaticResource AccentTeal}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsContinuousTempScan}" Value="True">
                                                        <Setter Property="Content" Value="■  STOP"/>
                                                        <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Command>
                                            <Binding Path="ToggleContinuousTempScanCommand"/>
                                        </Button.Command>
                                    </Button>
                                    <TextBlock Grid.Column="4"
                                               Text="Interwał:" Foreground="{StaticResource TextMuted}"
                                               FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <ComboBox Grid.Column="5"
                                              ItemsSource="{Binding ScanIntervals}"
                                              SelectedItem="{Binding SelectedTempScanInterval}"
                                              Width="75" Height="34" Margin="4,0,0,0"/>
                                </Grid>
                            </Grid>

                            <!-- Results DataGrid -->
                            <TextBlock Text="WYNIKI TEMPERATURY" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="0,16,0,6"/>

                            <DataGrid ItemsSource="{Binding TempResults}"
                                      Height="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Kanał"     Width="80"
                                                        Binding="{Binding ChannelId}"/>
                                    <DataGridTextColumn Header="Temp [°C]" Width="*"
                                                        Binding="{Binding Value, StringFormat=F3}"/>
                                    <DataGridTextColumn Header="Jednostka" Width="70"
                                                        Binding="{Binding Unit}"/>
                                    <DataGridTextColumn Header="TC"        Width="50"
                                                        Binding="{Binding Function}"/>
                                    <DataGridTextColumn Header="Czas"      Width="100"
                                                        Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ══════════════════════ BOTTOM BAR ══════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="RESET"
                        Style="{StaticResource RedButton}"
                        Command="{Binding ResetCommand}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="1" Content="STATUS"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding QueryStatusCommand}"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           FontSize="11"/>

                <TextBlock Grid.Column="3"
                           Text="Agilent 34970A v1.0"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
