<Window x:Class="Agilent34970A.Views.ScanConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja skanu" Width="380"
        SizeToContent="Height" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#D4D0CC">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Background" Value="#C8C4C0"/>
            <Setter Property="BorderBrush" Value="#9A9694"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Background" Value="#C8C4C0"/>
            <Setter Property="BorderBrush" Value="#9A9694"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">
        <TextBlock Text="WYZWALANIE I PRZEBIEGI" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>

        <TextBlock Text="Źródło wyzwalania:"/>
        <ComboBox ItemsSource="{Binding TriggerSources}"
                  SelectedItem="{Binding SelectedTriggerSource}"/>

        <TextBlock Text="Odstęp timera [s] (gdy TIMER):"/>
        <TextBox Text="{Binding TimerIntervalText, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Liczba przebiegów skanu:"/>
        <TextBox Text="{Binding ScanCount, UpdateSourceTrigger=PropertyChanged}"/>

        <Border Background="#C0BCB8" BorderBrush="#9A9694" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,12,0,0">
            <StackPanel>
                <CheckBox Content="Ustaw opóźnienie kanału" IsChecked="{Binding UseChannelDelay}"
                          Foreground="#202020" FontWeight="SemiBold"/>
                <TextBlock Text="Opóźnienie kanału [s]:"/>
                <TextBox Text="{Binding ChannelDelayText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding UseChannelDelay}"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Uwaga: dla BUS/EXT skan czeka na wyzwolenie — odczyt może długo trwać."
                   TextWrapping="Wrap" Foreground="#7A5500" Margin="0,12,0,0"/>

        <Button Content="OK" Width="100" Height="32"
                HorizontalAlignment="Right" Margin="0,16,0,0"
                Background="#1A73C8" Foreground="White" BorderThickness="0"
                Click="OnOkClick"/>
    </StackPanel>
</Window>
