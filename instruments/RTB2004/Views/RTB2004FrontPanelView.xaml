<UserControl x:Class="RTB2004.Views.RTB2004FrontPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d"
             d:DesignHeight="940" d:DesignWidth="860"
             MinWidth="720" MinHeight="680"
             Background="#1E2232">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="PanelBg"    Color="#1E2232"/>
        <SolidColorBrush x:Key="SectionBg"  Color="#283044"/>
        <SolidColorBrush x:Key="BorderClr"  Color="#465070"/>
        <SolidColorBrush x:Key="LabelFg"    Color="#A0B0D0"/>
        <SolidColorBrush x:Key="RsBrand"    Color="#0066B3"/>
        <SolidColorBrush x:Key="StatusBg"   Color="#181C2A"/>

        <SolidColorBrush x:Key="Ch1Color"   Color="#FFFF00"/>
        <SolidColorBrush x:Key="Ch2Color"   Color="#00FFFF"/>
        <SolidColorBrush x:Key="Ch3Color"   Color="#FF66FF"/>
        <SolidColorBrush x:Key="Ch4Color"   Color="#66FF66"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LabelFg}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValBox" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#14182A"/>
            <Setter Property="Foreground" Value="#88AAEE"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3,1"/>
            <Setter Property="CaretBrush" Value="#88AAEE"/>
        </Style>

        <Style x:Key="CbBox" TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#14182A"/>
            <Setter Property="Foreground" Value="#88AAEE"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderClr}"/>
        </Style>

        <Style x:Key="AcqBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.60"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmBtn" TargetType="Button" BasedOn="{StaticResource AcqBtn}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource RsBrand}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#181C2A"
            BorderBrush="{StaticResource BorderClr}"
            BorderThickness="1" CornerRadius="6" Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>           <!-- 0  brand             -->
                <RowDefinition Height="Auto"/>           <!-- 1  scope status bar  -->
                <RowDefinition Height="Auto"/>           <!-- 2  channels          -->
                <RowDefinition Height="Auto"/>           <!-- 3  timebase+trigger  -->
                <RowDefinition Height="Auto"/>           <!-- 4  acquisition ctrl  -->
                <RowDefinition Height="Auto"/>           <!-- 5  measurements      -->
                <RowDefinition Height="*" MinHeight="160"/>  <!-- 6  waveform view -->
                <RowDefinition Height="Auto"/>           <!-- 7  tools+reset       -->
                <RowDefinition Height="Auto"/>           <!-- 8  status bar        -->
            </Grid.RowDefinitions>

            <!-- ── Brand strip ─────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#10141E" CornerRadius="5,5,0,0" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Rohde &amp; Schwarz" Foreground="{StaticResource RsBrand}"
                                   FontFamily="Arial" FontSize="10" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="RTB2004"
                               Foreground="White" FontFamily="Arial" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="DIGITAL OSCILLOSCOPE" Foreground="#6680AA"
                                   FontSize="8" HorizontalAlignment="Right"/>
                        <TextBlock Text="4 CH  |  300 MHz" Foreground="{StaticResource RsBrand}"
                                   FontSize="9" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Oscilloscope status bar (simulated screen header) ────────── -->
            <Border Grid.Row="1" Background="#090E1E"
                    BorderBrush="#222844" BorderThickness="2" CornerRadius="3"
                    Margin="14,6,14,0" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="2" Padding="5,2" Margin="0,0,6,0" Background="#1A1400">
                        <TextBlock Text="{Binding Ch1Label}" Foreground="{StaticResource Ch1Color}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="1" CornerRadius="2" Padding="5,2" Margin="0,0,6,0" Background="#001414">
                        <TextBlock Text="{Binding Ch2Label}" Foreground="{StaticResource Ch2Color}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="2" Padding="5,2" Margin="0,0,6,0" Background="#190019">
                        <TextBlock Text="{Binding Ch3Label}" Foreground="{StaticResource Ch3Color}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <Border Grid.Column="3" CornerRadius="2" Padding="5,2" Margin="0,0,12,0" Background="#001900">
                        <TextBlock Text="{Binding Ch4Label}" Foreground="{StaticResource Ch4Color}"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <TextBlock Grid.Column="5"
                               Text="{Binding TimescaleDisplay}"
                               Foreground="#AABBEE" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Border Grid.Column="6" CornerRadius="3" Padding="8,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2040"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AcquisitionState}" Value="RUN">
                                        <Setter Property="Background" Value="#003300"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AcquisitionState}" Value="SINGLE">
                                        <Setter Property="Background" Value="#332200"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding AcquisitionState}"
                                   Foreground="#88DDAA" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Channels ────────────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                    CornerRadius="4" Margin="14,6,14,0" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="KANAŁY" Style="{StaticResource SecTitle}"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header row -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="ON" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Skala [V/dz]" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Column="6" Text="Offset [V]" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Column="9" Text="Sprzęż." Style="{StaticResource FieldLabel}"/>
                            <TextBlock Grid.Column="12" Text="Sonda" Style="{StaticResource FieldLabel}"/>
                        </Grid>

                        <!-- CH1 -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CH1" Foreground="{StaticResource Ch1Color}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding Ch1Enabled}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="V/dz:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="4" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ScaleOptions}" SelectedItem="{Binding Ch1Scale}"/>
                            <TextBlock Grid.Column="6" Text="Offs:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="7" Style="{StaticResource ValBox}"
                                     Text="{Binding Ch1Offset, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="9" Text="Spr:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="10" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding CouplingOptions}" SelectedItem="{Binding Ch1Coupling}"/>
                            <TextBlock Grid.Column="12" Text="x:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="13" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ProbeOptions}" SelectedItem="{Binding Ch1Probe}"/>
                        </Grid>

                        <!-- CH2 -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CH2" Foreground="{StaticResource Ch2Color}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding Ch2Enabled}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="V/dz:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="4" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ScaleOptions}" SelectedItem="{Binding Ch2Scale}"/>
                            <TextBlock Grid.Column="6" Text="Offs:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="7" Style="{StaticResource ValBox}"
                                     Text="{Binding Ch2Offset, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="9" Text="Spr:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="10" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding CouplingOptions}" SelectedItem="{Binding Ch2Coupling}"/>
                            <TextBlock Grid.Column="12" Text="x:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="13" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ProbeOptions}" SelectedItem="{Binding Ch2Probe}"/>
                        </Grid>

                        <!-- CH3 -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="CH3" Foreground="{StaticResource Ch3Color}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="1" IsChecked="{Binding Ch3Enabled}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="V/dz:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="4" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ScaleOptions}" SelectedItem="{Binding Ch3Scale}"/>
                            <TextBlock Grid.Column="6" Text="Offs:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="7" Style="{StaticResource ValBox}"
                                     Text="{Binding Ch3Offset, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="9" Text="Spr:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="10" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding CouplingOptions}" SelectedItem="{Binding Ch3Coupling}"/>
                            <TextBlock Grid.Column="12" Text="x:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="13" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding ProbeOptions}" SelectedItem="{Binding Ch3Probe}"/>
                        </Grid>
                    </Grid>

                    <!-- CH4 -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CH4" Foreground="{StaticResource Ch4Color}"
                                   FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding Ch4Enabled}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="V/dz:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="4" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ScaleOptions}" SelectedItem="{Binding Ch4Scale}"/>
                        <TextBlock Grid.Column="6" Text="Offs:" Style="{StaticResource FieldLabel}"/>
                        <TextBox Grid.Column="7" Style="{StaticResource ValBox}"
                                 Text="{Binding Ch4Offset, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="9" Text="Spr:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="10" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding CouplingOptions}" SelectedItem="{Binding Ch4Coupling}"/>
                        <TextBlock Grid.Column="12" Text="x:" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Grid.Column="13" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ProbeOptions}" SelectedItem="{Binding Ch4Probe}"/>
                        <Button Grid.Column="15" Content="ZASTOSUJ" Width="80"
                                Background="{StaticResource RsBrand}" Style="{StaticResource SmBtn}"
                                Command="{Binding ApplyChannelsCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Timebase + Trigger ──────────────────────────────────────── -->
            <Grid Grid.Row="3" Margin="14,5,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SectionBg}"
                        BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                        CornerRadius="4" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="PODSTAWA CZASU" Style="{StaticResource SecTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="s/dz:" Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding TimebaseOptions}" SelectedItem="{Binding SelectedTimescale}"/>
                            <TextBlock Grid.Column="2" Text="s" Style="{StaticResource FieldLabel}" Margin="4,0,8,0"/>
                            <Button Grid.Column="3" Content="OK" Width="40"
                                    Background="#224488" Style="{StaticResource SmBtn}"
                                    Command="{Binding ApplyTimescaleCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource SectionBg}"
                        BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                        CornerRadius="4" Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="WYZWALANIE" Style="{StaticResource SecTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Źr:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding TriggerSources}" SelectedItem="{Binding TriggerSource}"/>
                            <TextBlock Grid.Column="3" Text="Poz:" Style="{StaticResource FieldLabel}"/>
                            <TextBox Grid.Column="4" Style="{StaticResource ValBox}"
                                     Text="{Binding TriggerLevel, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="6" Text="Zb:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="7" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding TriggerSlopes}" SelectedItem="{Binding TriggerSlope}"/>
                            <TextBlock Grid.Column="9" Text="Tr:" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Grid.Column="10" Style="{StaticResource CbBox}"
                                      ItemsSource="{Binding TriggerModes}" SelectedItem="{Binding TriggerMode}"/>
                            <Button Grid.Column="12" Content="OK" Width="40"
                                    Background="#224488" Style="{StaticResource SmBtn}"
                                    Command="{Binding ApplyTriggerCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Acquisition control ────────────────────────────────────── -->
            <Border Grid.Row="4" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="STEROWANIE AKWIZYCJĄ" Style="{StaticResource SecTitle}"/>
                    <UniformGrid Rows="1" Columns="4">
                        <Button Content="RUN"    Background="#1A5C1A" Margin="2"
                                Style="{StaticResource AcqBtn}" Command="{Binding RunCommand}"/>
                        <Button Content="STOP"   Background="#5C1A1A" Margin="2"
                                Style="{StaticResource AcqBtn}" Command="{Binding StopCommand}"/>
                        <Button Content="SINGLE" Background="#5C3A00" Margin="2"
                                Style="{StaticResource AcqBtn}" Command="{Binding SingleCommand}"/>
                        <Button Content="AUTO"   Background="#004466" Margin="2"
                                Style="{StaticResource AcqBtn}" Command="{Binding AutoscaleCommand}"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- ── Measurements ───────────────────────────────────────────── -->
            <Border Grid.Row="5" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0" Padding="10,8">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="POMIARY" Style="{StaticResource SecTitle}"/>
                        <Button Grid.Column="1" Content="ODSWIEZ" Width="80"
                                Background="#223355" Style="{StaticResource SmBtn}"
                                Command="{Binding UpdateMeasurementsCommand}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- M1 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="M1" Foreground="#AABB88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ChannelSources}" SelectedItem="{Binding M1Source}"/>
                        <ComboBox Grid.Row="0" Grid.Column="3" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding MeasTypes}" SelectedItem="{Binding M1Type}"/>
                        <Border Grid.Row="0" Grid.Column="5" Background="#14182A"
                                BorderBrush="{StaticResource BorderClr}" BorderThickness="1" CornerRadius="2" Padding="6,2">
                            <TextBlock Text="{Binding M1Result}" Foreground="#88DDAA"
                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding M1Unit}"
                                   Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>

                        <!-- M2 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="M2" Foreground="#AABB88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ChannelSources}" SelectedItem="{Binding M2Source}"/>
                        <ComboBox Grid.Row="2" Grid.Column="3" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding MeasTypes}" SelectedItem="{Binding M2Type}"/>
                        <Border Grid.Row="2" Grid.Column="5" Background="#14182A"
                                BorderBrush="{StaticResource BorderClr}" BorderThickness="1" CornerRadius="2" Padding="6,2">
                            <TextBlock Text="{Binding M2Result}" Foreground="#88DDAA"
                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="2" Grid.Column="6" Text="{Binding M2Unit}"
                                   Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>

                        <!-- M3 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="M3" Foreground="#AABB88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ChannelSources}" SelectedItem="{Binding M3Source}"/>
                        <ComboBox Grid.Row="4" Grid.Column="3" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding MeasTypes}" SelectedItem="{Binding M3Type}"/>
                        <Border Grid.Row="4" Grid.Column="5" Background="#14182A"
                                BorderBrush="{StaticResource BorderClr}" BorderThickness="1" CornerRadius="2" Padding="6,2">
                            <TextBlock Text="{Binding M3Result}" Foreground="#88DDAA"
                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="4" Grid.Column="6" Text="{Binding M3Unit}"
                                   Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>

                        <!-- M4 -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="M4" Foreground="#AABB88"
                                   FontFamily="Consolas" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding ChannelSources}" SelectedItem="{Binding M4Source}"/>
                        <ComboBox Grid.Row="6" Grid.Column="3" Style="{StaticResource CbBox}"
                                  ItemsSource="{Binding MeasTypes}" SelectedItem="{Binding M4Type}"/>
                        <Border Grid.Row="6" Grid.Column="5" Background="#14182A"
                                BorderBrush="{StaticResource BorderClr}" BorderThickness="1" CornerRadius="2" Padding="6,2">
                            <TextBlock Text="{Binding M4Result}" Foreground="#88DDAA"
                                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="6" Grid.Column="6" Text="{Binding M4Unit}"
                                   Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Oscilloscope waveform view ─────────────────────────────── -->
            <Border Grid.Row="6" Background="#05080F"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header bar with channel labels and capture button -->
                    <Grid Grid.Row="0" Background="#0E1428">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,3,0,3">
                            <Border Background="#221C00" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding Ch1Label}" Foreground="{StaticResource Ch1Color}"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <Border Background="#001C1C" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding Ch2Label}" Foreground="{StaticResource Ch2Color}"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <Border Background="#220022" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                <TextBlock Text="{Binding Ch3Label}" Foreground="{StaticResource Ch3Color}"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <Border Background="#002200" CornerRadius="2" Padding="4,1" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Ch4Label}" Foreground="{StaticResource Ch4Color}"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding TimescaleDisplay}" Foreground="#7090B8"
                                       FontFamily="Consolas" FontSize="9" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="ODCZYT PRZEBIEGÓW"
                                Background="#1A2E50" Style="{StaticResource SmBtn}"
                                Margin="0,2,6,2" Padding="10,0"
                                Command="{Binding CaptureWaveformCommand}"
                                IsEnabled="{Binding IsConnected}"/>
                    </Grid>

                    <!-- OxyPlot waveform display -->
                    <oxy:PlotView Grid.Row="1" Model="{Binding ScopeModel}"
                                  Background="Transparent" MinHeight="150"/>
                </Grid>
            </Border>

            <!-- ── Tools + Reset ──────────────────────────────────────────── -->
            <Grid Grid.Row="7" Margin="14,5,14,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="SCREENSHOT"
                        Background="#1A3318" Style="{StaticResource AcqBtn}"
                        Command="{Binding TakeScreenshotCommand}"/>
                <Button Grid.Column="2" Content="ZAPISZ PRESET"
                        Background="#1A2840" Style="{StaticResource AcqBtn}"
                        Command="{Binding SavePresetCommand}"/>
                <Button Grid.Column="4" Content="WCZYTAJ PRESET"
                        Background="#1A2840" Style="{StaticResource AcqBtn}"
                        Command="{Binding LoadPresetCommand}"/>
                <Button Grid.Column="6" Content="LIVE DATA"
                        Background="#003344" Style="{StaticResource AcqBtn}"
                        Command="{Binding OpenLiveWindowCommand}"/>
                <Button Grid.Column="8" Content="RESET"
                        Background="#3A1020" Style="{StaticResource AcqBtn}"
                        Command="{Binding ResetCommand}"/>
            </Grid>

            <!-- ── Status bar ─────────────────────────────────────────────── -->
            <Border Grid.Row="8" Background="{StaticResource StatusBg}"
                    BorderBrush="{StaticResource BorderClr}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,5,5" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#2A2A55"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource RsBrand}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                               Foreground="{StaticResource LabelFg}"
                               FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" Text="R&amp;S RTB2004  |  4CH 300MHz"
                               Foreground="#506070" FontFamily="Consolas" FontSize="9"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
