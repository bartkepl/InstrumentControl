<UserControl x:Class="ItechIT6922B.Views.ItechIT6922BFrontPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="780"
             MinWidth="660" MinHeight="560"
             Background="#262A3E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="PanelBg"        Color="#262A3E"/>
        <SolidColorBrush x:Key="BezelBg"         Color="#1E2240"/>
        <SolidColorBrush x:Key="DisplayBg"       Color="#000000"/>
        <SolidColorBrush x:Key="DisplayGreen"    Color="#00FF7F"/>
        <SolidColorBrush x:Key="DisplayDimGreen" Color="#003A1A"/>
        <SolidColorBrush x:Key="SectionBg"       Color="#323658"/>
        <SolidColorBrush x:Key="BorderColor"     Color="#505880"/>
        <SolidColorBrush x:Key="LabelFg"         Color="#B0BAD8"/>
        <SolidColorBrush x:Key="ItechBlue"       Color="#0066CC"/>
        <SolidColorBrush x:Key="StatusBg"        Color="#1E2240"/>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LabelFg}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueBox" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#1C2038"/>
            <Setter Property="Foreground" Value="#90C8FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="CaretBrush" Value="#90C8FF"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.60"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5599EE"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BezelBg}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1" CornerRadius="6" Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0  brand strip   -->
                <RowDefinition Height="Auto"/>  <!-- 1  display       -->
                <RowDefinition Height="Auto"/>  <!-- 2  output ctrl   -->
                <RowDefinition Height="Auto"/>  <!-- 3  setpoints     -->
                <RowDefinition Height="Auto"/>  <!-- 4  protection    -->
                <RowDefinition Height="Auto"/>  <!-- 5  continuous    -->
                <RowDefinition Height="Auto"/>  <!-- 6  read / reset  -->
                <RowDefinition Height="*"/>     <!-- 7  spacer        -->
                <RowDefinition Height="Auto"/>  <!-- 8  status bar    -->
            </Grid.RowDefinitions>

            <!-- ── Brand strip ─────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#161A2E" CornerRadius="5,5,0,0" Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ITECH" Foreground="{StaticResource ItechBlue}"
                                   FontFamily="Arial" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="Electronic" Foreground="#4488CC"
                                   FontFamily="Arial" FontSize="7"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="IT6922B"
                               Foreground="White" FontFamily="Arial" FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="PROGRAMMABLE" Foreground="#6688AA" FontSize="8" HorizontalAlignment="Right"/>
                        <TextBlock Text="DC POWER SUPPLY" Foreground="{StaticResource ItechBlue}"
                                   FontSize="8" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock Text="60V / 5A" Foreground="#88AACC" FontSize="9" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Display ─────────────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="{StaticResource DisplayBg}"
                    BorderBrush="#001A08" BorderThickness="3" CornerRadius="4"
                    Margin="14,8,14,2" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Voltage -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="VOLTAGE" Foreground="{StaticResource DisplayDimGreen}"
                                   FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayVoltage}"
                                   Foreground="{StaticResource DisplayGreen}"
                                   FontFamily="Consolas" FontSize="38" FontWeight="Bold"
                                   HorizontalAlignment="Right">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FF7F" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="V" Foreground="{StaticResource DisplayGreen}"
                                   FontFamily="Consolas" FontSize="14" HorizontalAlignment="Right" Margin="0,-6,0,0"/>
                    </StackPanel>

                    <!-- Current -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CURRENT" Foreground="{StaticResource DisplayDimGreen}"
                                   FontFamily="Consolas" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayCurrent}"
                                   Foreground="{StaticResource DisplayGreen}"
                                   FontFamily="Consolas" FontSize="38" FontWeight="Bold"
                                   HorizontalAlignment="Right">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FF7F" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="A" Foreground="{StaticResource DisplayGreen}"
                                   FontFamily="Consolas" FontSize="14" HorizontalAlignment="Right" Margin="0,-6,0,0"/>
                    </StackPanel>

                    <!-- Mode + Power column -->
                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Width="70">
                        <Border CornerRadius="4" Padding="6,4" Margin="0,0,0,6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#003308"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OperatingMode}" Value="CC">
                                            <Setter Property="Background" Value="#440000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding OperatingMode}"
                                       Foreground="{StaticResource DisplayGreen}"
                                       FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="POWER" Foreground="{StaticResource DisplayDimGreen}"
                                   FontFamily="Consolas" FontSize="8" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding DisplayPower}"
                                   Foreground="{StaticResource DisplayGreen}"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="W" Foreground="{StaticResource DisplayDimGreen}"
                                   FontFamily="Consolas" FontSize="9" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Output control ──────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    CornerRadius="4" Margin="14,6,14,0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock Text="OUTPUT" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#441111"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputEnabled}" Value="True">
                                                <Setter Property="Fill" Value="#00FF44"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="OFF"/>
                                        <Setter Property="Foreground" Value="#884444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputEnabled}" Value="True">
                                                <Setter Property="Text" Value="ON"/>
                                                <Setter Property="Foreground" Value="#00FF44"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="80" Command="{Binding OutputOnCommand}"
                                Background="#006622" Foreground="White"
                                Style="{StaticResource ActionBtn}" Content="OUTPUT ON"
                                FontSize="11" Margin="0,0,6,0"/>
                        <Button Width="80" Command="{Binding OutputOffCommand}"
                                Background="#660022" Foreground="White"
                                Style="{StaticResource ActionBtn}" Content="OUTPUT OFF"
                                FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Setpoints ────────────────────────────────────────────────── -->
            <Border Grid.Row="3" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Voltage -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NAPIĘCIE WYJŚCIOWE" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="V:"
                                       Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding VoltageSetpoint, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ValueBox}"/>
                            <TextBlock Grid.Column="2" Text="V"
                                       Style="{StaticResource FieldLabel}" Margin="4,0,8,0"/>
                            <Button Grid.Column="3" Content="USTAW" Width="55"
                                    Background="{StaticResource ItechBlue}"
                                    Style="{StaticResource SmBtn}"
                                    Command="{Binding ApplyVoltageCommand}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Current -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LIMIT PRĄDU" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="I:"
                                       Style="{StaticResource FieldLabel}" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentLimit, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ValueBox}"/>
                            <TextBlock Grid.Column="2" Text="A"
                                       Style="{StaticResource FieldLabel}" Margin="4,0,8,0"/>
                            <Button Grid.Column="3" Content="USTAW" Width="55"
                                    Background="#006688"
                                    Style="{StaticResource SmBtn}"
                                    Command="{Binding ApplyCurrentCommand}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Protection ───────────────────────────────────────────────── -->
            <Border Grid.Row="4" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="OCHRONA" Style="{StaticResource SectionTitle}"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- OVP -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="OVP (Nadnapięcie)" Foreground="#8866AA"
                                       FontSize="9" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding OvpEnabled}"
                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                          Foreground="{StaticResource LabelFg}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OvpLevel, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ValueBox}"/>
                                <TextBlock Grid.Column="2" Text="V"
                                           Style="{StaticResource FieldLabel}" Margin="4,0,8,0"/>
                                <Button Grid.Column="3" Content="OK" Width="36"
                                        Background="#440088"
                                        Style="{StaticResource SmBtn}"
                                        Command="{Binding ApplyOvpCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- OCP -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="OCP (Nadprąd)" Foreground="#884444"
                                       FontSize="9" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding OcpEnabled}"
                                          VerticalAlignment="Center" Margin="0,0,6,0"
                                          Foreground="{StaticResource LabelFg}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OcpLevel, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ValueBox}"/>
                                <TextBlock Grid.Column="2" Text="A"
                                           Style="{StaticResource FieldLabel}" Margin="4,0,8,0"/>
                                <Button Grid.Column="3" Content="OK" Width="36"
                                        Background="#660022"
                                        Style="{StaticResource SmBtn}"
                                        Command="{Binding ApplyOcpCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Clear -->
                        <Button Grid.Column="4" Content="CLR PROT" Width="80"
                                Background="#333344" Foreground="#AAAACC"
                                Style="{StaticResource SmBtn}"
                                Command="{Binding ClearProtectionCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── Continuous measurement ────────────────────────────────────── -->
            <Border Grid.Row="5" Background="{StaticResource SectionBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    CornerRadius="4" Margin="14,5,14,0" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Width="120" Command="{Binding ToggleContinuousCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                <Setter Property="Content" Value="▶  CIĄGŁY POMIAR"/>
                                <Setter Property="Background" Value="{StaticResource ItechBlue}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsContinuous}" Value="True">
                                        <Setter Property="Content" Value="■  STOP"/>
                                        <Setter Property="Background" Value="#880022"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Grid.Column="2" Text="Interwał:"
                               Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding Intervals}"
                              SelectedItem="{Binding SelectedInterval}"
                              Height="26" Background="#1C2038" Foreground="#90C8FF"
                              BorderBrush="{StaticResource BorderColor}"
                              FontFamily="Consolas"/>
                    <TextBlock Grid.Column="5" Text="ms"
                               Style="{StaticResource FieldLabel}" Margin="4,0,0,0"/>

                    <Button Grid.Column="7" Content="▶ LIVE" Width="60" Height="26"
                            Background="#004455" Foreground="#80E8FF"
                            Style="{StaticResource SmBtn}"
                            Command="{Binding OpenLiveWindowCommand}"/>
                </Grid>
            </Border>

            <!-- ── Read settings / Reset ─────────────────────────────────────── -->
            <Grid Grid.Row="6" Margin="14,6,14,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="▶  POMIAR JEDNORAZOWY"
                        Style="{StaticResource ActionBtn}"
                        Background="#003366"
                        Command="{Binding MeasureOnceCommand}"/>
                <Button Grid.Column="2" Content="⟳  ODCZYT NASTAW"
                        Style="{StaticResource ActionBtn}"
                        Background="#1A2040"
                        Command="{Binding ReadSetpointsCommand}"/>
                <Button Grid.Column="4" Content="⟳  RESET"
                        Style="{StaticResource ActionBtn}"
                        Background="#440011"
                        Command="{Binding ResetCommand}"/>
            </Grid>

            <!-- ── Status bar ─────────────────────────────────────────────────── -->
            <Border Grid.Row="8" Background="{StaticResource StatusBg}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,5,5" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#333355"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource ItechBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               Foreground="{StaticResource LabelFg}"
                               FontFamily="Consolas" FontSize="10"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2"
                               Text="ITECH IT6922B  |  60V / 5A"
                               Foreground="#445566" FontFamily="Consolas" FontSize="9"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
