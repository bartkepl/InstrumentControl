<UserControl x:Class="InstrumentControl.App.Views.DataViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             Background="{StaticResource BackgroundBrush}">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="White" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding ClearDataCommand}" Margin="2,0">
                    <TextBlock Text="{DynamicResource DataViewer_Clear}"/>
                </Button>
                <Button Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding ExportCsvCommand}" Margin="2,0">
                    <TextBlock Text="{DynamicResource DataViewer_ExportCsv}"/>
                </Button>
                <Separator Margin="4,0"/>
                <TextBlock Text="{Binding ResultCountDisplay}" VerticalAlignment="Center" FontSize="12" Foreground="#7F8C8D"/>
            </StackPanel>
        </Border>

        <!-- Split: table top, chart bottom -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Data grid -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="8,8,8,0">
                <DataGrid x:Name="ResultsGrid"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          AlternatingRowBackground="#F8F9FA"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeight="24" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Loaded="ResultsGrid_Loaded">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="90"/>
                        <DataGridTextColumn Binding="{Binding InstrumentName}" Width="130"/>
                        <DataGridTextColumn Binding="{Binding ChannelId}" Width="60"/>
                        <DataGridTextColumn Binding="{Binding ParameterName}" Width="130"/>
                        <DataGridTextColumn Binding="{Binding Value, StringFormat=G8}" Width="100"/>
                        <DataGridTextColumn Binding="{Binding Unit}" Width="70"/>
                        <DataGridTextColumn Binding="{Binding Function}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#BDC3C7"/>

            <!-- Chart -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="8,0,8,8">
                <oxy:PlotView Model="{Binding PlotModel}" Background="White"/>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
