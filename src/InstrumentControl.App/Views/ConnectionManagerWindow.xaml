<Window x:Class="InstrumentControl.App.Views.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ConnMgr_Title}" Height="780" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       Margin="0,0,10,0" FontSize="12" Foreground="#7F8C8D" MaxWidth="300"
                       TextWrapping="Wrap"/>
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding TestConnectionCommand}" Margin="4,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="{DynamicResource ConnMgr_TestConnection}"/>
            </Button>
            <Button Style="{StaticResource SuccessButtonStyle}"
                    Command="{Binding ConnectCommand}" Margin="4,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="{DynamicResource ConnMgr_Connect}"/>
            </Button>
            <Button Style="{StaticResource DangerButtonStyle}"
                    Click="Cancel_Click" Margin="4,0">
                <TextBlock Text="{DynamicResource ConnMgr_Cancel}"/>
            </Button>
        </StackPanel>

        <StackPanel>
            <!-- VISA resources -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{DynamicResource ConnMgr_VisaResources}" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Left"/>
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding RefreshResourcesCommand}"
                                HorizontalAlignment="Right" FontSize="12">
                            <TextBlock Text="{DynamicResource ConnMgr_Refresh}"/>
                        </Button>
                    </DockPanel>
                    <ListBox x:Name="ResourceList" Height="140"
                             ItemsSource="{Binding AvailableResources}"
                             SelectedItem="{Binding SelectedResource}"
                             Margin="0,4,0,0" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="{DynamicResource ConnMgr_ManualHint}"
                               FontSize="11" Foreground="#7F8C8D" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding ManualResourceString, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- Driver selection -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ConnMgr_Driver}" Style="{StaticResource SectionHeaderStyle}"/>
                    <ListBox Height="190" ItemsSource="{Binding AvailableDrivers}"
                             SelectedItem="{Binding SelectedDriver}" Margin="0,4,0,0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <!-- Gray out non-matching drivers after auto-detection -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGrayedOut}" Value="True">
                                        <Setter Property="Opacity" Value="0.35"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- "✓ wykryto" badge — visible only on matched driver -->
                                    <Border Grid.Column="0" CornerRadius="3"
                                            Background="#27AE60" Padding="5,1"
                                            Margin="0,0,7,0" VerticalAlignment="Center"
                                            Visibility="{Binding IsDetected, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{DynamicResource ConnMgr_Detected}" Foreground="White"
                                                   FontSize="10" FontWeight="Bold"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Auto-detect progress -->
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,6,0,0"
                                 Visibility="{Binding IsAutoDetecting, Converter={StaticResource BoolToVis}}"/>

                    <!-- Detected IDN response -->
                    <TextBlock Text="{Binding DetectedIdnText}" FontSize="11"
                               Foreground="#27AE60" Margin="0,4,0,0" TextWrapping="Wrap"
                               Visibility="{Binding DetectedIdnText.Length,
                                   Converter={StaticResource LengthToVisConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ConnMgr_Options}" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <CheckBox IsChecked="{Binding UseSimulation}" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource ConnMgr_SimMode}"/>
                        </CheckBox>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource ConnMgr_LabelHint}"
                               FontSize="11" Foreground="#7F8C8D" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding InstrumentLabel, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" Tag="{DynamicResource ConnMgr_LabelPlaceholder}"/>

                    <TextBlock Text="{Binding TestResult}" FontSize="12" Foreground="#3498DB"
                               Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding TestResult.Length, Converter={StaticResource LengthToVisConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
