<Window x:Class="InstrumentControl.App.Views.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj przyrząd" Height="720" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       Margin="0,0,10,0" FontSize="12" Foreground="#7F8C8D" MaxWidth="300"
                       TextWrapping="Wrap"/>
            <Button Content="Test połączenia" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding TestConnectionCommand}" Margin="4,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Połącz" Style="{StaticResource SuccessButtonStyle}"
                    Command="{Binding ConnectCommand}" Margin="4,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Anuluj" Style="{StaticResource DangerButtonStyle}"
                    Click="Cancel_Click" Margin="4,0"/>
        </StackPanel>

        <StackPanel>
            <!-- VISA resources -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Zasoby VISA" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Left"/>
                        <Button Content="🔄 Odśwież" Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding RefreshResourcesCommand}"
                                HorizontalAlignment="Right" FontSize="12"/>
                    </DockPanel>
                    <ListBox x:Name="ResourceList" Height="140"
                             ItemsSource="{Binding AvailableResources}"
                             SelectedItem="{Binding SelectedResource}"
                             Margin="0,4,0,0" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Lub wpisz ręcznie (GPIB0::22::INSTR, COM3, ...)"
                               FontSize="11" Foreground="#7F8C8D" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding ManualResourceString, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" FontFamily="Consolas"/>
                </StackPanel>
            </Border>

            <!-- Driver selection -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Driver przyrządu" Style="{StaticResource SectionHeaderStyle}"/>
                    <ListBox Height="130" ItemsSource="{Binding AvailableDrivers}"
                             SelectedItem="{Binding SelectedDriver}" Margin="0,4,0,0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Options -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Opcje" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <CheckBox Content="Tryb symulacji (bez fizycznego urządzenia)"
                                  IsChecked="{Binding UseSimulation}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Etykieta przyrządu (opcjonalna):"
                               FontSize="11" Foreground="#7F8C8D" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding InstrumentLabel, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,4" Tag="np. DMM1, Zasilacz_lab3"/>

                    <TextBlock Text="{Binding TestResult}" FontSize="12" Foreground="#3498DB"
                               Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding TestResult.Length, Converter={StaticResource LengthToVisConverter}}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
