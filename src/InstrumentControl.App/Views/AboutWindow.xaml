<Window x:Class="InstrumentControl.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="O programie" Width="380" Height="340"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#ECF0F1"
        Icon="/Resources/InstrumentControl.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="24,20">
            <StackPanel Orientation="Horizontal">
                <Image Source="/Resources/InstrumentControl.ico" Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="InstrumentControl" Foreground="White"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" Foreground="#95A5A6"
                               FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,20,24,0" VerticalAlignment="Top">

            <TextBlock Text="AUTOR" FontSize="10" FontWeight="Bold"
                       Foreground="#95A5A6" Margin="0,0,0,6"/>
            <TextBlock Text="Bartek" FontSize="14" Foreground="#2C3E50" Margin="0,0,0,16"/>

            <TextBlock Text="REPOZYTORIUM" FontSize="10" FontWeight="Bold"
                       Foreground="#95A5A6" Margin="0,0,0,6"/>
            <TextBlock FontSize="13" Margin="0,0,0,16">
                <Hyperlink x:Name="GithubLink" RequestNavigate="GithubLink_RequestNavigate"
                           NavigateUri="https://github.com/bartkepl/InstrumentControl"
                           Foreground="#3498DB">
                    github.com/bartkepl/InstrumentControl
                </Hyperlink>
            </TextBlock>

            <Separator Margin="0,0,0,16"/>

            <!-- Placeholder: language selection -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="JĘZYK / LANGUAGE" FontSize="10" FontWeight="Bold"
                           Foreground="#95A5A6" VerticalAlignment="Center"/>
                <TextBlock Text="  (wkrótce)" FontSize="10" Foreground="#BDC3C7"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Polski" FontSize="13" Foreground="#BDC3C7"
                       Margin="0,6,0,0"/>

        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="16,12" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="#D5D8DC">
            <Button Content="Zamknij" Click="CloseButton_Click"
                    HorizontalAlignment="Right"
                    Background="#2C3E50" Foreground="White"
                    Padding="20,7" BorderThickness="0" Cursor="Hand"
                    FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>
    </Grid>
</Window>
