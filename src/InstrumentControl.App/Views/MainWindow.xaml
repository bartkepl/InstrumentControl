<Window x:Class="InstrumentControl.App.Views.MainWindow"
        Icon="/Resources/InstrumentControl.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InstrumentControl.App.ViewModels"
        xmlns:views="clr-namespace:InstrumentControl.App.Views"
        Title="InstrumentControl" Height="900" Width="1400"
        MinHeight="640" MinWidth="1000"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Top Menu -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Foreground="White">
            <Menu.Resources>
                <!-- Sub-items would inherit Foreground=White and be invisible on white popup bg.
                     Override: only TopLevelHeader keeps White, sub-items use dark text. -->
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Foreground" Value="#212121"/>
                    <Style.Triggers>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.Resources>
            <MenuItem Header="{DynamicResource Menu_File}">
                <MenuItem Header="{DynamicResource Menu_File_NewSequence}" Command="{Binding SeqVm.NewSequenceCommand}"/>
                <MenuItem Header="{DynamicResource Menu_File_OpenSequence}" Command="{Binding SeqVm.OpenSequenceCommand}"/>
                <MenuItem Header="{DynamicResource Menu_File_SaveSequence}" Command="{Binding SeqVm.SaveSequenceCommand}"/>
                <MenuItem Header="{DynamicResource Menu_File_SaveSequenceAs}" Command="{Binding SeqVm.SaveSequenceAsCommand}"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Menu_File_Exit}" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Instrument}">
                <MenuItem Header="{DynamicResource Menu_Instrument_Add}" Click="MenuAddInstrument_Click"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu_Data}">
                <MenuItem Header="{DynamicResource Menu_Data_Clear}" Command="{Binding DataVm.ClearDataCommand}"/>
                <MenuItem Header="{DynamicResource Menu_Data_ExportCsv}" Command="{Binding DataVm.ExportCsvCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" Height="40" Background="#F8F9FA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ToolBar Grid.Column="0" Background="#F8F9FA" Height="40">
                <Button Style="{StaticResource AccentButtonStyle}" Margin="2,0"
                        Click="MenuAddInstrument_Click"
                        Content="{DynamicResource Toolbar_AddInstrument}"
                        ToolTip="{DynamicResource Toolbar_AddInstrumentTip}"/>
                <Separator/>
                <Button Style="{StaticResource SuccessButtonStyle}" Margin="2,0"
                        Command="{Binding SeqVm.RunSequenceCommand}"
                        Content="{DynamicResource Toolbar_Run}"
                        ToolTip="{DynamicResource Toolbar_RunTip}"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" Margin="2,0"
                        Command="{Binding SeqVm.PauseSequenceCommand}">
                    <TextBlock Text="{Binding SeqVm.IsPaused, Converter={StaticResource PauseResumeConverter}}"
                               Foreground="White"/>
                </Button>
                <Button Style="{StaticResource DangerButtonStyle}" Margin="2,0"
                        Command="{Binding SeqVm.StopSequenceCommand}" IsEnabled="{Binding SeqVm.IsRunning}"
                        Content="{DynamicResource Toolbar_Stop}"/>
                <Separator/>
                <Button Style="{StaticResource BaseButtonStyle}" Background="White" Margin="2,0"
                        Command="{Binding SeqVm.OpenSequenceCommand}"
                        Content="{DynamicResource Toolbar_Open}"/>
                <Button Style="{StaticResource BaseButtonStyle}" Background="White" Margin="2,0"
                        Command="{Binding SeqVm.SaveSequenceCommand}"
                        Content="{DynamicResource Toolbar_Save}"/>
            </ToolBar>
            <Button Grid.Column="1" Click="AboutButton_Click"
                    Background="Transparent" BorderThickness="0"
                    Margin="0,0,8,0" Padding="10,0" Cursor="Hand"
                    ToolTip="{DynamicResource About_Title}" VerticalAlignment="Stretch"
                    Foreground="#7F8C8D" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8ECF0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="{DynamicResource Toolbar_About}"/>
            </Button>
        </Grid>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PrimaryBrush}" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding MainVm.StatusBarText}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SeqVm.SequenceStatusDisplay}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding MainVm.IsVisaSimulated, Converter={StaticResource SimModeConverter}}"
                           Foreground="#F39C12" FontSize="11" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Connected Instruments -->
            <DockPanel Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10,8">
                    <TextBlock Text="{DynamicResource Sidebar_Instruments}" FontSize="11" FontWeight="Bold"
                               Foreground="#95A5A6"/>
                </Border>
                <Button DockPanel.Dock="Bottom" Margin="8" Style="{StaticResource AccentButtonStyle}"
                        Click="MenuAddInstrument_Click">
                    <TextBlock Text="{DynamicResource Sidebar_AddInstrument}"/>
                </Button>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MainVm.ConnectedInstruments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectedInstrumentVm}">
                                <Border Style="{StaticResource InstrumentItemStyle}"
                                        MouseLeftButtonDown="InstrumentItem_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ResourceName}" Foreground="#95A5A6"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding StatusText}" Foreground="#27AE60"
                                                       FontSize="11" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕" Background="Transparent"
                                                Foreground="#95A5A6" BorderThickness="0" FontSize="12"
                                                VerticalAlignment="Top" Cursor="Hand"
                                                Command="{Binding DataContext.MainVm.RemoveInstrumentCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"
                          Background="#BDC3C7"/>

            <!-- Main Content: Tab Control -->
            <TabControl Grid.Column="2" x:Name="MainTabControl"
                        Background="{StaticResource BackgroundBrush}"
                        BorderThickness="0">
                <TabItem Header="{DynamicResource Tab_FrontPanel}">
                    <views:FrontPanelView x:Name="FrontPanelView"
                                          DataContext="{Binding MainVm.SelectedInstrument}"/>
                </TabItem>
                <TabItem Header="{DynamicResource Tab_SequenceEditor}">
                    <views:SequenceEditorView x:Name="SeqEditorView"
                                              DataContext="{Binding SeqVm}"/>
                </TabItem>
                <TabItem Header="{DynamicResource Tab_Data}">
                    <views:DataViewerView x:Name="DataViewerView"
                                          DataContext="{Binding DataVm}"/>
                </TabItem>
                <TabItem Header="{DynamicResource Tab_Log}">
                    <Border Padding="8" Background="White">
                        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogBox" IsReadOnly="True"
                                     Text="{Binding SeqVm.LogText, Mode=OneWay}"
                                     FontFamily="Consolas" FontSize="12"
                                     Background="White" BorderThickness="0"
                                     TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
