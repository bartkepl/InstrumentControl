<Window x:Class="InstrumentControl.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InstrumentControl.App.ViewModels"
        xmlns:views="clr-namespace:InstrumentControl.App.Views"
        Title="InstrumentControl" Height="900" Width="1400"
        MinHeight="640" MinWidth="1000"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Top Menu -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource PrimaryBrush}" Foreground="White">
            <MenuItem Header="_Plik" Foreground="{StaticResource PrimaryBrush}">
                <MenuItem Header="Nowa sekwencja" Command="{Binding SeqVm.NewSequenceCommand}"/>
                <MenuItem Header="Otwórz sekwencję..." Command="{Binding SeqVm.OpenSequenceCommand}"/>
                <MenuItem Header="Zapisz sekwencję" Command="{Binding SeqVm.SaveSequenceCommand}"/>
                <MenuItem Header="Zapisz sekwencję jako..." Command="{Binding SeqVm.SaveSequenceAsCommand}"/>
                <Separator/>
                <MenuItem Header="Wyjście" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Instrument" Foreground="{StaticResource PrimaryBrush}">
                <MenuItem Header="Dodaj przyrząd..." Click="MenuAddInstrument_Click"/>
            </MenuItem>
            <MenuItem Header="_Dane" Foreground="{StaticResource PrimaryBrush}">
                <MenuItem Header="Wyczyść dane" Command="{Binding DataVm.ClearDataCommand}"/>
                <MenuItem Header="Eksport CSV..." Command="{Binding DataVm.ExportCsvCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Background="#F8F9FA" Height="40">
            <Button Style="{StaticResource AccentButtonStyle}" Margin="2,0"
                    Click="MenuAddInstrument_Click" ToolTip="Dodaj przyrząd (Ctrl+N)">
                ➕ Dodaj przyrząd
            </Button>
            <Separator/>
            <Button Style="{StaticResource SuccessButtonStyle}" Margin="2,0"
                    Command="{Binding SeqVm.RunSequenceCommand}" ToolTip="Uruchom sekwencję (F5)">
                ▶ Uruchom
            </Button>
            <Button Style="{StaticResource PrimaryButtonStyle}" Margin="2,0"
                    Command="{Binding SeqVm.PauseSequenceCommand}">
                <TextBlock Text="{Binding SeqVm.IsPaused, Converter={StaticResource PauseResumeConverter}}"/>
            </Button>
            <Button Style="{StaticResource DangerButtonStyle}" Margin="2,0"
                    Command="{Binding SeqVm.StopSequenceCommand}" IsEnabled="{Binding SeqVm.IsRunning}">
                ■ Stop
            </Button>
            <Separator/>
            <Button Style="{StaticResource BaseButtonStyle}" Background="White" Margin="2,0"
                    Command="{Binding SeqVm.OpenSequenceCommand}">
                📂 Otwórz
            </Button>
            <Button Style="{StaticResource BaseButtonStyle}" Background="White" Margin="2,0"
                    Command="{Binding SeqVm.SaveSequenceCommand}">
                💾 Zapisz
            </Button>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource PrimaryBrush}" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding MainVm.StatusBarText}" FontSize="12"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock FontSize="12">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Sekwencja: {0}">
                            <Binding Path="SeqVm.SequenceStatus"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding MainVm.IsVisaSimulated, Converter={StaticResource SimModeConverter}}"
                           Foreground="#F39C12" FontSize="11" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: Connected Instruments -->
            <DockPanel Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10,8">
                    <TextBlock Text="PRZYRZĄDY" FontSize="11" FontWeight="Bold"
                               Foreground="#95A5A6"/>
                </Border>
                <Button DockPanel.Dock="Bottom" Margin="8" Style="{StaticResource AccentButtonStyle}"
                        Click="MenuAddInstrument_Click">
                    + Dodaj przyrząd
                </Button>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MainVm.ConnectedInstruments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConnectedInstrumentVm}">
                                <Border Style="{StaticResource InstrumentItemStyle}"
                                        MouseLeftButtonDown="InstrumentItem_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                       FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ResourceName}" Foreground="#95A5A6"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding StatusText}" Foreground="#27AE60"
                                                       FontSize="11" Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="✕" Background="Transparent"
                                                Foreground="#95A5A6" BorderThickness="0" FontSize="12"
                                                VerticalAlignment="Top" Cursor="Hand"
                                                Command="{Binding DataContext.MainVm.RemoveInstrumentCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"
                          Background="#BDC3C7"/>

            <!-- Main Content: Tab Control -->
            <TabControl Grid.Column="2" x:Name="MainTabControl"
                        Background="{StaticResource BackgroundBrush}"
                        BorderThickness="0">
                <TabItem Header="🖥  Panel frontowy">
                    <views:FrontPanelView x:Name="FrontPanelView"
                                          DataContext="{Binding MainVm.SelectedInstrument}"/>
                </TabItem>
                <TabItem Header="⚙  Edytor sekwencji">
                    <views:SequenceEditorView x:Name="SeqEditorView"
                                              DataContext="{Binding SeqVm}"/>
                </TabItem>
                <TabItem Header="📊  Dane / Wykresy">
                    <views:DataViewerView x:Name="DataViewerView"
                                          DataContext="{Binding DataVm}"/>
                </TabItem>
                <TabItem Header="📋  Log">
                    <Border Padding="8" Background="White">
                        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="LogBox" IsReadOnly="True"
                                     Text="{Binding SeqVm.LogText, Mode=OneWay}"
                                     FontFamily="Consolas" FontSize="12"
                                     Background="White" BorderThickness="0"
                                     TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
